# ===========================================
# GeoTask Pro v2 - Environment Variables
# ===========================================

# Database (PostgreSQL)
# For local Docker: postgresql://geotask:geotask_dev_2024@localhost:5433/geotask_v2
# For Neon: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://geotask:geotask_dev_2024@localhost:5433/geotask_v2"
DIRECT_URL="postgresql://geotask:geotask_dev_2024@localhost:5433/geotask_v2"

# JWT Authentication
JWT_SECRET="change-me-to-a-secure-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-secure-random-string-min-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# File Storage
# LOCAL = disk storage (dev)
# S3 = AWS S3 (production)
STORAGE_DRIVER="LOCAL"
UPLOAD_DIR="./uploads"

# AWS S3 (production only)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="sa-east-1"
# AWS_S3_BUCKET="geotask-pro-v2"

# External APIs
# ReceitaWS - CNPJ lookup
RECEITAWS_URL="https://receitaws.com.br/v1/cnpj"
RECEITAWS_TOKEN=""

# Ecoleta Social API
ECOLETA_API_URL=""
ECOLETA_API_EMAIL=""
ECOLETA_API_PASSWORD=""

# CPF Lookup API
CPF_API_URL=""
CPF_API_TOKEN=""

# Admin Security
# Password required for destructive operations (delete)
ADMIN_DEV_PASSWORD="change-me"

# Docker Compose (used by docker-compose.yml)
DB_USER="geotask"
DB_PASSWORD="geotask_dev_2024"
DB_NAME="geotask_v2"
PGADMIN_EMAIL="admin@geotask.com"
PGADMIN_PASSWORD="admin123"
