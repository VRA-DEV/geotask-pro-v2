generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id                   Int              @id @default(autoincrement())
  name                 String
  email                String           @unique
  password_hash        String
  role_id              Int
  sector_id            Int
  team_id              Int?
  client_id            Int?
  avatar               String?
  active               Boolean          @default(true)
  must_change_password Boolean          @default(true)
  user_type            String           @default("INTERNAL") // INTERNAL | EXTERNAL
  refresh_token        String?
  last_login_at        DateTime?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  deleted_at           DateTime?

  role                 Role             @relation(fields: [role_id], references: [id])
  sector               Sector           @relation(fields: [sector_id], references: [id])
  team                 Team?            @relation(fields: [team_id], references: [id])
  client               Client?          @relation(fields: [client_id], references: [id])
  user_sectors         UserSector[]

  // Task relations
  tasks_created        Task[]           @relation("CreatedBy")
  tasks_responsible    Task[]           @relation("Responsible")
  task_coworkers       TaskUser[]
  task_history         TaskHistory[]
  subtasks             Subtask[]
  comments             Comment[]
  mentions_created     Mention[]        @relation("MentionedBy")
  mentions_received    Mention[]        @relation("MentionedUser")
  notifications        Notification[]
  templates            Template[]
  template_subtasks    TemplateSubtask[]
  task_attachments     TaskAttachment[]

  // Contract/Delivery relations
  contracts_created    Contract[]       @relation("ContractCreator")
  deliveries_created   Delivery[]       @relation("DeliveryCreator")
  delivery_replacements DeliveryHistory[] @relation("DeliveryReplacer")
  imports_created      Import[]

  // Financial relations
  invoices_generated   Invoice[]        @relation("InvoiceGenerator")
  invoices_billed      Invoice[]        @relation("InvoiceBiller")
  invoices_rejected    Invoice[]        @relation("InvoiceRejecter")
  payments_confirmed   Payment[]        @relation("PaymentConfirmer")

  // Logs
  activity_logs        ActivityLog[]
  audit_logs           AuditLog[]

  @@index([team_id])
  @@index([client_id])
  @@index([role_id])
  @@index([sector_id])
  @@index([user_type])
  @@index([deleted_at])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  users       User[]
}

model Sector {
  id                Int               @id @default(autoincrement())
  name              String            @unique
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  users             User[]
  user_sectors      UserSector[]
  tasks             Task[]
  subtasks          Subtask[]
  mentions          Mention[]
  templates         Template[]
  template_subtasks TemplateSubtask[]
  task_types        TaskType[]
}

model Team {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users      User[]
  tasks      Task[]
}

model UserSector {
  id         Int      @id @default(autoincrement())
  user_id    Int
  sector_id  Int
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sector     Sector   @relation(fields: [sector_id], references: [id], onDelete: Cascade)

  @@unique([user_id, sector_id])
  @@index([user_id])
  @@index([sector_id])
}

model TaskType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  sector_id  Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  sector     Sector?  @relation(fields: [sector_id], references: [id], onDelete: SetNull)

  @@index([sector_id])
}

// ============================================================
// TASKS MODULE (migrated from v1)
// ============================================================

model Task {
  id              Int              @id @default(autoincrement())
  title           String
  description     String?
  type            String?
  status          String           @default("A Fazer")
  priority        String?
  sector_id       Int?
  responsible_id  Int?
  contract_id     Int?
  city_id         Int?
  neighborhood_id Int?
  nucleus         String?
  quadra          String?
  lote            String?
  deadline        DateTime?
  link            String?
  created_by_id   Int?
  team_id         Int?
  parent_id       Int?
  time_spent      Int              @default(0)
  created_at      DateTime         @default(now())
  updated_at      DateTime?        @updatedAt
  started_at      DateTime?
  paused_at       DateTime?
  completed_at    DateTime?
  deleted_at      DateTime?

  sector          Sector?          @relation(fields: [sector_id], references: [id])
  responsible     User?            @relation("Responsible", fields: [responsible_id], references: [id])
  created_by      User?            @relation("CreatedBy", fields: [created_by_id], references: [id])
  task_contract   TaskContract?    @relation(fields: [contract_id], references: [id])
  city            City?            @relation(fields: [city_id], references: [id])
  neighborhood    Neighborhood?    @relation(fields: [neighborhood_id], references: [id])
  team            Team?            @relation(fields: [team_id], references: [id])
  parent          Task?            @relation("TaskSubtasks", fields: [parent_id], references: [id])
  children        Task[]           @relation("TaskSubtasks")

  subtasks        Subtask[]
  comments        Comment[]
  mentions        Mention[]
  notifications   Notification[]
  history         TaskHistory[]
  pauses          TaskPause[]
  coworkers       TaskUser[]
  attachments     TaskAttachment[]

  @@index([responsible_id])
  @@index([sector_id])
  @@index([status])
  @@index([parent_id])
  @@index([created_by_id])
  @@index([team_id])
  @@index([deleted_at])
}

// Renamed from "Contract" in v1 to avoid conflict with new Contract module
model TaskContract {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  tasks         Task[]
  neighborhoods Neighborhood[]
}

model City {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  neighborhoods Neighborhood[]
  tasks         Task[]
}

model Neighborhood {
  id               Int           @id @default(autoincrement())
  name             String
  city_id          Int
  task_contract_id Int?
  city             City          @relation(fields: [city_id], references: [id], onDelete: Cascade)
  task_contract    TaskContract? @relation(fields: [task_contract_id], references: [id], onDelete: SetNull)
  tasks            Task[]

  @@unique([city_id, name])
}

model Subtask {
  id             Int       @id @default(autoincrement())
  title          String
  done           Boolean   @default(false)
  sector_id      Int?
  task_id        Int
  responsible_id Int?
  done_at        DateTime?
  task           Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  responsible    User?     @relation(fields: [responsible_id], references: [id])
  sector         Sector?   @relation(fields: [sector_id], references: [id])
}

model Comment {
  id            Int            @id @default(autoincrement())
  content       String
  created_at    DateTime       @default(now())
  task_id       Int
  user_id       Int?
  task          Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [user_id], references: [id])
  mentions      Mention[]
  notifications Notification[]

  @@index([task_id])
}

model TaskPause {
  id         Int       @id @default(autoincrement())
  task_id    Int
  started_at DateTime  @default(now())
  ended_at   DateTime?
  task       Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Mention {
  id                  Int      @id @default(autoincrement())
  mention_type        String
  mentioned_sector_id Int?
  created_at          DateTime @default(now())
  comment_id          Int
  task_id             Int
  mentioned_user_id   Int?
  mentioned_by_id     Int?
  comment             Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  task                Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  mentioned_by        User?    @relation("MentionedBy", fields: [mentioned_by_id], references: [id])
  mentioned_user      User?    @relation("MentionedUser", fields: [mentioned_user_id], references: [id])
  sector              Sector?  @relation(fields: [mentioned_sector_id], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  type       String
  title      String
  message    String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  user_id    Int
  task_id    Int?
  comment_id Int?
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [task_id], references: [id])
  comment    Comment? @relation(fields: [comment_id], references: [id])

  @@index([user_id, read])
  @@index([task_id])
}

model TaskHistory {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int?
  field      String
  old_value  String?
  new_value  String?
  created_at DateTime @default(now())
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([task_id])
}

model TaskUser {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int
  created_at DateTime @default(now())
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([task_id, user_id])
  @@index([task_id])
  @@index([user_id])
}

model TaskAttachment {
  id             Int      @id @default(autoincrement())
  task_id        Int
  filename       String
  original_name  String
  mime_type      String
  size           Int
  url            String
  uploaded_by_id Int?
  created_at     DateTime @default(now())
  task           Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  uploaded_by    User?    @relation(fields: [uploaded_by_id], references: [id])

  @@index([task_id])
}

model Template {
  id            Int            @id @default(autoincrement())
  name          String
  sector_id     Int
  created_by_id Int?
  created_at    DateTime       @default(now())
  created_by    User?          @relation(fields: [created_by_id], references: [id])
  sector        Sector         @relation(fields: [sector_id], references: [id])
  tasks         TemplateTask[]
}

model TemplateTask {
  id          Int               @id @default(autoincrement())
  title       String
  order_index Int               @default(0)
  template_id Int
  template    Template          @relation(fields: [template_id], references: [id], onDelete: Cascade)
  subtasks    TemplateSubtask[]
}

model TemplateSubtask {
  id               Int          @id @default(autoincrement())
  title            String
  order_index      Int          @default(0)
  template_task_id Int
  sector_id        Int?
  responsible_id   Int?
  template_task    TemplateTask @relation(fields: [template_task_id], references: [id], onDelete: Cascade)
  sector           Sector?      @relation(fields: [sector_id], references: [id])
  responsible      User?        @relation(fields: [responsible_id], references: [id])
}

// ============================================================
// CLIENTS MODULE (new)
// ============================================================

model Client {
  id            Int       @id @default(autoincrement())
  cnpj          String    @unique
  razao_social  String
  nome_fantasia String?
  endereco      String?
  cidade        String?
  estado        String?
  cep           String?
  telefone      String?
  email         String?
  api_data      Json?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  users         User[]
  contracts     Contract[]

  @@index([deleted_at])
}

// ============================================================
// CONTRACTS MODULE (new)
// ============================================================

model Contract {
  id                  Int       @id @default(autoincrement())
  number              String    @unique
  client_id           Int
  start_date          DateTime
  end_date            DateTime
  contracted_quantity Int
  status              String    @default("ATIVO") // ATIVO, ENCERRADO, CANCELADO
  created_by_id       Int
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  client              Client    @relation(fields: [client_id], references: [id])
  created_by          User      @relation("ContractCreator", fields: [created_by_id], references: [id])
  items               ContractItem[]
  distributions       GeographicDistribution[]
  measurement_rules   MeasurementRule[]
  lots                Lot[]
  invoices            Invoice[]

  @@index([client_id])
  @@index([status])
  @@index([deleted_at])
}

model ContractItem {
  id            Int       @id @default(autoincrement())
  contract_id   Int
  description   String
  unit          String
  unit_value    Decimal   @db.Decimal(12, 2)
  quantity      Int
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  contract      Contract  @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  deliveries    Delivery[]
  billing_rules BillingRule[]
  lot_executions LotItemExecution[]

  @@index([contract_id])
}

model GeographicDistribution {
  id            Int       @id @default(autoincrement())
  contract_id   Int
  state         String
  city          String
  nucleus       String?
  quantity      Int
  created_at    DateTime  @default(now())

  contract      Contract  @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  @@index([contract_id])
}

model MeasurementRule {
  id            Int       @id @default(autoincrement())
  contract_id   Int
  field         String    // CATEGORIA, STATUS_PROCESSO
  values        Json      // Array de valores aceitos
  active        Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  contract      Contract  @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  @@index([contract_id])
}

// ============================================================
// LOTS MODULE (new)
// ============================================================

model Lot {
  id              Int       @id @default(autoincrement())
  contract_id     Int
  external_id     String?
  code            String
  beneficiary     String?
  cpf             String?
  address         String?
  neighborhood    String?
  city            String?
  state           String?
  zip_code        String?
  latitude        Float?
  longitude       Float?
  geometry_wkt    String?   @db.Text
  category        String?
  process_status  String?
  area            Float?
  metadata        Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  contract        Contract  @relation(fields: [contract_id], references: [id])
  deliveries      Delivery[]
  import_details  ImportDetail[]
  lot_executions  LotItemExecution[]

  @@index([contract_id])
  @@index([code])
  @@index([cpf])
  @@index([external_id])
  @@index([deleted_at])
}

model Import {
  id            Int       @id @default(autoincrement())
  type          String    // SHAPEFILE, API_ECOLETA
  filename      String?
  status        String    @default("PENDING") // PENDING, CONFIRMED, CANCELLED, ERROR
  contract_id   Int?
  total_records Int       @default(0)
  created_count Int       @default(0)
  updated_count Int       @default(0)
  deleted_count Int       @default(0)
  preview_data  Json?
  created_by_id Int
  created_at    DateTime  @default(now())
  confirmed_at  DateTime?

  created_by    User      @relation(fields: [created_by_id], references: [id])
  details       ImportDetail[]

  @@index([status])
  @@index([created_by_id])
}

model ImportDetail {
  id            Int       @id @default(autoincrement())
  import_id     Int
  lot_id        Int?
  action        String    // CREATE, UPDATE, DELETE, KEEP
  changes       Json?
  created_at    DateTime  @default(now())

  import_record Import    @relation(fields: [import_id], references: [id], onDelete: Cascade)
  lot           Lot?      @relation(fields: [lot_id], references: [id])

  @@index([import_id])
}

// ============================================================
// DELIVERIES MODULE (new)
// ============================================================

model Delivery {
  id               Int       @id @default(autoincrement())
  lot_id           Int
  contract_item_id Int
  type             String    // PRODUTO, CRF_1, PROTOCOLO, CRF_FINAL, DEVOLUTIVA
  subtype          String?
  file_url         String?
  link             String?
  protocol_number  String?
  protocol_date    DateTime?
  delivered_at     DateTime
  created_by_id    Int
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  lot              Lot       @relation(fields: [lot_id], references: [id])
  contract_item    ContractItem @relation(fields: [contract_item_id], references: [id])
  created_by       User      @relation("DeliveryCreator", fields: [created_by_id], references: [id])
  history          DeliveryHistory[]

  @@index([lot_id])
  @@index([contract_item_id])
}

model DeliveryHistory {
  id               Int       @id @default(autoincrement())
  delivery_id      Int
  previous_url     String?
  previous_link    String?
  new_url          String?
  new_link         String?
  reason           String
  retroactive_date DateTime?
  replaced_by_id   Int
  replaced_at      DateTime  @default(now())

  delivery         Delivery  @relation(fields: [delivery_id], references: [id], onDelete: Cascade)
  replaced_by      User      @relation("DeliveryReplacer", fields: [replaced_by_id], references: [id])

  @@index([delivery_id])
}

// ============================================================
// FINANCIAL MODULE (new)
// ============================================================

model BillingRule {
  id               Int          @id @default(autoincrement())
  contract_item_id Int
  field            String       // CATEGORIA, STATUS_PROCESSO
  values           Json
  active           Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  contract_item    ContractItem @relation(fields: [contract_item_id], references: [id], onDelete: Cascade)

  @@index([contract_item_id])
}

model LotItemExecution {
  id               Int          @id @default(autoincrement())
  lot_id           Int
  contract_item_id Int
  billable         Boolean      @default(false)
  billed           Boolean      @default(false)
  invoice_id       Int?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  lot              Lot          @relation(fields: [lot_id], references: [id])
  contract_item    ContractItem @relation(fields: [contract_item_id], references: [id])
  invoice          Invoice?     @relation(fields: [invoice_id], references: [id])

  @@unique([lot_id, contract_item_id])
  @@index([lot_id])
  @@index([contract_item_id])
  @@index([invoice_id])
}

model Invoice {
  id              Int       @id @default(autoincrement())
  contract_id     Int
  number          String?
  status          String    @default("AGUARDANDO") // AGUARDANDO, FATURADO, RECUSADO
  total_lots      Int
  total_value     Decimal?  @db.Decimal(12, 2)
  reject_reason   String?
  generated_data  Json?
  generated_by_id Int
  billed_by_id    Int?
  billed_at       DateTime?
  rejected_by_id  Int?
  rejected_at     DateTime?
  created_at      DateTime  @default(now())

  contract        Contract  @relation(fields: [contract_id], references: [id])
  generated_by    User      @relation("InvoiceGenerator", fields: [generated_by_id], references: [id])
  billed_by       User?     @relation("InvoiceBiller", fields: [billed_by_id], references: [id])
  rejected_by     User?     @relation("InvoiceRejecter", fields: [rejected_by_id], references: [id])
  payments        Payment[]
  lot_executions  LotItemExecution[]

  @@index([contract_id])
  @@index([status])
}

model Payment {
  id              Int       @id @default(autoincrement())
  invoice_id      Int
  nf_number       String?
  nf_file_url     String?
  order_file_url  String?
  amount          Decimal   @db.Decimal(12, 2)
  paid_at         DateTime?
  confirmed_by_id Int
  created_at      DateTime  @default(now())

  invoice         Invoice   @relation(fields: [invoice_id], references: [id])
  confirmed_by    User      @relation("PaymentConfirmer", fields: [confirmed_by_id], references: [id])

  @@index([invoice_id])
}

// ============================================================
// AUDIT & LOGGING
// ============================================================

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  user_name  String
  action     String
  entity     String?
  entity_id  Int?
  details    String?
  ip_address String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([action])
  @@index([created_at])
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  action      String    // CREATE, UPDATE, DELETE, LOGIN, EXPORT
  entity      String    // User, Task, Contract, Lot, etc
  entity_id   Int?
  before_data Json?
  after_data  Json?
  description String?
  ip_address  String?
  user_agent  String?
  created_at  DateTime  @default(now())

  user        User?     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([entity, entity_id])
  @@index([action])
  @@index([created_at])
}
